{
  "name": "librico",
  "version": "1.0.0",
  "description": "A digital assistant for managing school library resources.",
  "main": "main.js",
  "workspaces": [
    "renderer"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "npm run dev --workspace=renderer",
    "dev:electron": "wait-on http://localhost:5173 && nodemon --exec \"electron .\"",
    "build": "npm run build --workspace=renderer",
    "package": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "TheDonDev",
    "email": "donaldmwanga33@gmail.com"
  },
  "license": "ISC",
  "build": {
    "appId": "com.librico.app",
    "productName": "Librico",
    "copyright": "Copyright © 2024 ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "!node_modules/bcrypt/build/Release/*.pdb",
      "main.js",
      "preload.js",
      "database.js",
      "renderer/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "./library.sqlite",
        "to": "library.sqlite"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "certificateFile": "librico-test-cert.pfx",
      "certificatePassword": "${env.CSC_KEY_PASSWORD}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "knex": "^3.1.0",
    "nodemailer": "^7.0.10",
    "sqlite3": "^5.1.7"
  }
}
