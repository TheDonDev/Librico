# Dependencies
# Ignore local dependencies installed by package managers.
/node_modules

# Build artifacts
# Ignore build output folders.
/build
/dist
/out

# Logs
# Ignore log files generated during development or by deployment.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
# Ignore environment-specific files. These often contain sensitive information.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor directories
# Ignore configuration files from common code editors.
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Operating System files
# Ignore files generated by the OS.
.DS_Store
Thumbs.db

# Test reports
# Ignore test coverage reports.
/coverage